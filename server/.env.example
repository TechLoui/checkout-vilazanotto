# ---------------------------------------------------------------------------
# Vila Zanotto Piri — variáveis de ambiente do backend de checkout
# Copie para `.env` e preencha. NUNCA versione o `.env` real.
#
# Reaproveita o mesmo código do Casa Zanotto. Se o Vila recebe na MESMA conta
# (Itaú + PV Rede), copie as mesmas credenciais do Casa; se tem conta/CNPJ
# próprios, gere credenciais próprias (Itaú: novo certificado + chave PIX;
# Rede: PV próprio). As variáveis do ARTAX_* mudam sempre (é outra propriedade).
# ---------------------------------------------------------------------------

# Porta do servidor
PORT=8080

# Ambiente: development | production
NODE_ENV=development

# Origem(ns) do site permitida(s) no CORS (separe por vírgula).
# Ex.: https://pousadacasazanotto.com,https://www.pousadacasazanotto.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- ArtaxNet (PMS) -------------------------------------------------------
# Credenciais fornecidas pelo Artax. Mantenha em segredo.
ARTAX_BASE_URL=https://artaxnet.com/pms-api/v1
ARTAX_CLIENT_ID=seu_client_id
ARTAX_CLIENT_SECRET=seu_client_secret

# Como o "price" da disponibilidade deve ser interpretado:
#   total      -> já é o total da estadia (padrão)
#   per_night  -> é por diária; o backend multiplica pelo nº de noites
ARTAX_PRICE_MODE=total

# Métodos de pagamento do Artax (GET /payment-methods). Já vêm com os IDs
# corretos da conta; só preencha para sobrescrever.
#   5957 = REDE | PIX · 8473 = REDE | CARTÃO DE CRÉDITO
ARTAX_PM_PIX=5957
ARTAX_PM_CARD=8473
# Centro de custo opcional para os lançamentos (GET /cost-centers). Vazio = não usa.
ARTAX_COST_CENTER_ID=

# Token usado pelo Artax para autenticar os webhooks que ELE envia ao nosso
# endpoint (Bearer + assinatura HMAC-SHA256 no header X-Signature).
ARTAX_WEBHOOK_TOKEN=defina_um_token_secreto_forte

# --- e.Rede (API v2, OAuth 2.0 — cartão + PIX no mesmo recurso) -----------
# Autenticação unificada: client_credentials -> access_token (Bearer).
# O backend gera/renova o token sozinho; você NÃO cola access_token.
# Em PRODUÇÃO: CLIENT_ID = seu PV e CLIENT_SECRET = sua chave de integração.
# No SANDBOX: credenciais de teste geradas no portal do desenvolvedor.
REDE_CLIENT_ID=seu_client_id_sandbox
REDE_CLIENT_SECRET=seu_client_secret_sandbox
# URLs — Sandbox (padrão):
REDE_OAUTH_URL=https://rl7-sandbox-api.useredecloud.com.br/oauth2/token
REDE_TRANSACTIONS_URL=https://sandbox-erede.useredecloud.com.br/v2/transactions
# URLs — Produção (troque quando for ao ar):
#   REDE_OAUTH_URL=https://api.userede.com.br/redelabs/oauth2/token
#   REDE_TRANSACTIONS_URL=https://api.userede.com.br/erede/v2/transactions

# Texto que aparece na fatura do cartão (máx. ~13 chars dinâmicos, sem acentos)
REDE_SOFT_DESCRIPTOR=CasaZanotto

# Máximo de parcelas permitido no checkout
MAX_INSTALLMENTS=6

# Token Bearer que o webhook PIX da Rede deve enviar p/ ser aceito (defina forte).
# Rota do webhook: POST /api/webhooks/erede/pix
REDE_WEBHOOK_TOKEN=defina_um_token_forte_do_webhook

# ⚠️ TESTE LOCAL: simula pagamento aprovado SEM chamar a Rede (a reserva no
# Artax é REAL). Deixe vazio/false em produção.
PAYMENT_SIMULATE=false

# --- PIX: qual provedor processa (cartão é sempre Rede) ---
# "rede" = e.Rede (acquirer) · "itau" = PIX Recebimentos do Itaú (direto no banco, mTLS)
PIX_PROVIDER=rede

# --- PIX Itaú (BACEN) — só se PIX_PROVIDER=itau ---
ITAU_CLIENT_ID=
ITAU_CLIENT_SECRET=
ITAU_PIX_KEY=
# Certificado e chave em base64 de uma linha (no Railway):
#   base64 -w0 itau.crt  -> ITAU_CERT_B64
#   base64 -w0 itau.key  -> ITAU_KEY_B64
ITAU_CERT_B64=
ITAU_KEY_B64=
# Dev local (alternativa ao base64): caminho dos arquivos
# ITAU_CERT_PATH=../pix/itau.crt
# ITAU_KEY_PATH=../pix/itau.key
# Padrões de produção (não precisa setar):
#   ITAU_OAUTH_URL=https://sts.itau.com.br/api/oauth/token
#   ITAU_BASE_URL=https://secure.api.itau/pix_recebimentos/v2
ITAU_PIX_EXPIRACAO=900

# --- E-mail de confirmação (Resend) ---------------------------------------
# Sem RESEND_API_KEY/RESEND_FROM o envio é DESATIVADO (não quebra a reserva).
RESEND_API_KEY=
# Remetente. PRODUÇÃO: use um domínio VERIFICADO no Resend, ex.:
#   RESEND_FROM="Vila Zanotto Piri <reservas@seudominio.com>"
# TESTE sem domínio: use o remetente do Resend — só entrega no e-mail da SUA
# conta Resend: RESEND_FROM="Vila Zanotto Piri <onboarding@resend.dev>"
RESEND_FROM=
RESEND_REPLY_TO=
RESEND_BCC=
# Marca do e-mail (têm default no código; sobrescreva se quiser):
BRAND_NAME=Vila Zanotto Piri
BRAND_COLOR=#f1bc0e
BRAND_LOGO_URL=https://checkout-vilazanotto.netlify.app/assets/logo.png
BRAND_SITE_URL=
BRAND_PHONE=
BRAND_ADDRESS=
